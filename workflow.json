            "index": 0
          }
        ]
      ]
    },
    "Conversation Memory": {
      "ai_memory": [
        [
          {
            "node": "Analysis (LLM Agent)",
            "type": "ai_memory",
            "index": 0
          }
        ]
      ]
    },
    "Connect Gemini 2": {
      "ai_languageModel": [
        [
          {
            "node": "Insight (LLM Agent)",
            "type": "ai_languageModel",
            "index": 0
          }
        ]
      ]
    },
    "Conversation Memory 2": {
